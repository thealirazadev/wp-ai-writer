# Local development only. Production configuration is entered on the plugin settings page;
# nothing in this file is read at runtime in production.

# Provider API key used when smoke-testing against the live LLM provider API from wp-env
AIWR_DEV_PROVIDER_API_KEY=sk-dummy-0000000000000000

# Optional endpoint override for pointing local dev at a mock provider server
AIWR_DEV_PROVIDER_ENDPOINT=http://localhost:8787

# Model identifier string to paste into the settings page during local testing
AIWR_DEV_MODEL=example-model-name
